    "rules":  [
                  {
                      "title":  "（一）需求评审规范",
                      "text":  "1 会议参与人员包括：产品、研发、\n  测试、业务相关方。\n2 输出《需求规格说明书》\n  《业务流程图》《UI设计稿》等文档。\n3 评审重点：范围、边界、业务规则、\n  验收标准、异常场景。",
                      "x":  24.55,
                      "y":  12.4,
                      "w":  3.75,
                      "h":  2.35,
                      "fontSize":  12.17
                  },
                  {
                      "title":  "（二）技术评审规范",
                      "text":  "1 输出《概要设计》《详细设计》\n  《接口文档》《数据字典》。\n2 评审架构、接口、数据、性能容量、\n  可测性和上线风险。\n3 评审结论必须形成整改清单。",
                      "x":  24.55,
                      "y":  9.65,
                      "w":  3.75,
                      "h":  2.25,
                      "fontSize":  12.17
                  },
                  {
                      "title":  "（三）测试准出标准",
                      "text":  "1 用例执行通过率 \u003e= 99%，核心用例 100% 通过。\n2 P0/P1/P2 缺陷全部关闭，遗留问题有明确风险接受。\n3 兼容、性能、数据迁移和关键业务链路验证完成。",
                      "x":  24.55,
                      "y":  6.75,
                      "w":  3.75,
                      "h":  2.55,
                      "fontSize":  12.17
                  },
                  {
                      "title":  "（四）发布与结项标准",
                      "text":  "1 发布前完成上线计划、回滚方案、\n  配置文档和监控清单。\n2 上线后完成关键路径验证\n  和生产问题跟踪。\n3 结项归档需求、设计、代码评审、\n  测试报告、验收清单和复盘总结。",
                      "x":  24.55,
                      "y":  3.65,
                      "w":  3.75,
                      "h":  2.75,
                      "fontSize":  12.17
                  }
              ],
